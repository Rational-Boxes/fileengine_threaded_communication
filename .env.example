# discussion service configuration — copy to .env and fill in. .env is gitignored.
# FILEENGINE_* names are shared with the core / bridges / mcp / CSAI; DISC_* are
# service-specific. See SPECIFICATION.md §14.

# --- gRPC core ---
FILEENGINE_GRPC_HOST=localhost
FILEENGINE_GRPC_PORT=50051

# --- This service's agent identity (internal maintenance only) ---
FILEENGINE_DISC_USER=
FILEENGINE_DISC_PASSWORD=
FILEENGINE_DISC_TENANT=default

# --- LDAP (auth/role authority) ---
FILEENGINE_LDAP_ENDPOINT=ldap://localhost:1389
FILEENGINE_LDAP_DOMAIN=dc=rationalboxes,dc=com
FILEENGINE_LDAP_USER_BASE=ou=users,dc=rationalboxes,dc=com
FILEENGINE_LDAP_TENANT_BASE=ou=tenants,dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_DN=cn=admin,dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_PASSWORD=admin

# --- Auth coordination with the http_bridge (accept its bearer tokens) ---
DISC_BRIDGE_URL=http://localhost:8090
# FILEENGINE_JWT_SECRET=   # if set, bridge JWTs are verified locally (no round-trip)

# --- This service's own Postgres (needs pgvector; dev PG runs on 5434) ---
DISC_PG_HOST=localhost
DISC_PG_PORT=5434
DISC_PG_DATABASE=discussion
DISC_PG_USER=fileengine_user
DISC_PG_PASSWORD=fileengine_password

# --- HTTP surface ---
DISC_HTTP_HOST=127.0.0.1
DISC_HTTP_PORT=8094
# DISC_CORS_ORIGINS=http://localhost:3000   # SPA dev origin (comma-separated)

# --- Events (M2+) ---
FILEENGINE_REDIS_HOST=localhost
FILEENGINE_REDIS_PORT=6379
# FILEENGINE_REDIS_PASSWORD=
FILEENGINE_EVENTS_STREAM=fileengine:events
DISC_EVENTS_GROUP=discussion
DISC_EMITS_STREAM=discussion:events

# --- Comment embeddings (M3) — dimension must match the model (fixes the schema) ---
DISC_EMBEDDING_DIMENSION=1024
DISC_EMBEDDING_PROVIDER=ollama
DISC_EMBEDDING_MODEL=nomic-embed-text

# --- Guardrails ---
DISC_MAX_COMMENT_CHARS=10000
DISC_MAX_RESULTS=100
DISC_DB_STATEMENT_TIMEOUT_MS=5000

# --- Real-time & presence (M4, §10h) ---
DISC_LIVE_ENABLED=true
DISC_PRESENCE_ENABLED=true
DISC_PRESENCE_ADMIN_INVISIBLE=true

# --- Email digest (M6, §11) ---
DISC_DIGEST_ENABLED=true
DISC_DIGEST_DEFAULT_CADENCE=off
# DISC_SPA_BASE_URL=https://your-tenant.example.com   # deep-link base for emails
